{
  "name": "squid-management-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --trace-warnings --abort-on-uncaught-exception --unhandled-rejections=strict dist/src/index.js",
    "start:watch": "nodemon src/index.ts",
    "check:code": "eslint src test",
    "check:prettier": "prettier -c '{src,test}/**/*.{js,ts,json,yml,md}'",
    "fix:code": "npm run check:code -- --fix",
    "fix:prettier": "npm run check:prettier -- --write",
    "test": "jest --forceExit --detectOpenHandles --coverage --verbose -c jest.config.json",
    "test:watch": "jest --watch --verbose -c jest.config.json",
    "lint": "eslint src test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.1034.0",
    "@dcl/core-commons": "^0.10.1",
    "@dcl/http-server": "^2.1.0",
    "@dcl/job-component": "^0.3.5",
    "@dcl/metrics": "^1.0.1",
    "@dcl/pg-component": "^0.2.0",
    "@dcl/schemas": "^26.1.0",
    "@dcl/slack-component": "^1.1.1",
    "@dcl/traced-fetch-component": "^1.0.8",
    "@dcl/tracer-component": "^1.0.0",
    "@well-known-components/env-config-provider": "^1.2.0",
    "@well-known-components/interfaces": "^1.5.2",
    "@well-known-components/logger": "^3.1.3",
    "pg": "^8.17.2",
    "sql-template-strings": "^2.2.2"
  },
  "devDependencies": {
    "@dcl/eslint-config": "^3.1.0",
    "@dcl/test-helpers": "^0.2.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.11.0",
    "jest": "^30.3.0",
    "nock": "^14.0.13",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
